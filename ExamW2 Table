/*Table - 8*/

define variable iCount      as integer   no-undo.
define variable iMaxCount   as integer   no-undo.
define variable cMaxKunde   as character no-undo.

/* loop check all S_Kunde */
for each S_Kunde
  where S_Kunde.Firma  = {firma/s_kunde.fir '100':U}
  no-lock:
  
  assign
    iCount = 0
    .
    
  /* count Artikel relation Kunde */
  for each S_Artkunde
    where S_Artkunde.Firma   = {firma/sartkund.fir '100':U}
      and S_Artkunde.Kunde   = S_Kunde.Kunde
    no-lock:
    
    assign
      iCount = iCount + 1
    .
    
    /* Check and collect the highest customer orders */
    if iCount > iMaxCount then
    do:
  
      assign
        iMaxCount   = iCount
        cMaxKunde   = string(S_Kunde.Kunde).
  
    end. /* if */
  end. /* for each bS_Artkunde */
end. /* for each S_Kunde */

if cMaxKunde <> '' then
do:
  display cMaxKunde   label 'Kunde':U
          iMaxCount   label 'Total Artikel':U.
end. /* if */

