/* ---------------------------------------------------------------------------- */

/*Table - 1*/

find first S_Artikel
  where S_Artikel.Firma    = {firma/sartikel.fir '100'}
    and S_Artikel.Artikel  begins '21'
  no-lock no-error.

if available S_Artikel then
do:
  display 'Output: ':U S_Artikel.Artikel.
end. /* if */


/* ---------------------------------------------------------------------------- */

/*Table - 2*/

find first S_Artikel
  where S_Artikel.Firma    = {firma/sartikel.fir '100'}
    and S_Artikel.Artikel  begins '10'
  no-lock no-error.

/*Find the last position of S_Kunde that is related to S_Artikel*/
if available S_Artikel then
do:
  find last S_Artkunde
    where S_Artkunde.Firma = {firma/s_kunde.fir '100':U}
      and string(S_Artkunde.Artikel) = S_Artikel.Artikel
    no-lock no-error.

  if available S_Artkunde then
  do:
    find S_Kunde
      where S_Kunde.Firma  = {firma/s_kunde.fir '100':U}
        and S_Kunde.Kunde  = S_Artkunde.Kunde
      no-lock no-error.

    if available S_Kunde then
     display 'Kunde: ':U S_Kunde.Kunde skip
             'Artikel: ':U S_Artikel.Artikel.
  end. /* if */
end. /* if */


/* ---------------------------------------------------------------------------- */

/*Table - 3*/

define buffer bFirstS_Artikel for S_Artikel.
define buffer bLastS_Artikel  for S_Artikel.

find first bFirstS_Artikel
  where bFirstS_Artikel.Firma = {firma/sartikel.fir '100':U}
  exclusive-lock no-error.

find last bLastS_Artikel
  where bLastS_Artikel.Firma = {firma/sartikel.fir '100':U}
  exclusive-lock no-error.

  /* sum first + last */
if available bFirstS_Artikel and available bLastS_Artikel then
do:
  assign
    bFirstS_Artikel.Selektion = string(bFirstS_Artikel.Gewicht + bLastS_Artikel.Gewicht)
    bLastS_Artikel.Selektion  = string(bFirstS_Artikel.Gewicht + bLastS_Artikel.Gewicht)
    .
end. /* if */

/* Result */
message
  'first: ':U bFirstS_Artikel.Artikel 'weight: ':U bFirstS_Artikel.Gewicht skip
  'last: ':U bLastS_Artikel.Artikel 'weight: ':U bLastS_Artikel.Gewicht skip
  'final: ':U bFirstS_Artikel.Gewicht + bLastS_Artikel.Gewicht.

/* ---------------------------------------------------------------------------- */

/*Table - 4*/

/* Loop find all S_Artikel */
for each S_Artikel
  where S_Artikel.Firma    = {firma/sartikel.fir '100':U}
  no-lock:

  /* Check S_Artikel in S_Artkunde*/
  find first S_Artkunde
    where S_Artkunde.Firma   = {firma/sartkund.fir '100':U}
      and S_Artkunde.Artikel = S_Artikel.Artikel
    no-lock no-error.

  /* Check Kunde have 1 */
  if available S_Artkunde then
  do:
      display 'Artikel: ':U S_Artikel.Artikel
              'ArtikelArt: ':U S_Artikel.ArtikelArt
              'LagerGewicht: ':U S_Artikel.LagerGewicht
              'First Kunde: ':U S_Artkunde.Kunde
              with width 120 down.
  end. /* if */
end. /* for */


/* ---------------------------------------------------------------------------- */

/*Table - 5*/

/* Loop Kunde 100000-100017 */
for each S_Kunde
  where S_Kunde.Firma  = {firma/s_kunde.fir '100'}
    and S_Kunde.Kunde  >= 100000
    and S_Kunde.Kunde  <= 100017
  no-lock:


  /* find relation S_Artkunde table */
  for each S_Artkunde
    where S_Artkunde.Firma   = {firma/sartkund.fir '100':U}
      and S_Artkunde.Kunde   = S_Kunde.Kunde
    no-lock:

    /* check condition ArtikelArt*/
    find S_Artikel
      where S_Artikel.Firma    = {firma/sartikel.fir '100':U}
        and S_Artikel.Artikel  = S_Artkunde.Artikel
      no-lock no-error.

    if available S_Artikel and lookup(string(S_Artikel.ArtikelArt), '61,10,9,5,1') > 0 then
    do:
      display 'Artikel: ':U S_Artikel.Artikel
              'ArtikelArt: ':U S_Artikel.ArtikelArt
              'Kunde: ':U S_Kunde.Kunde
              'Selektion ':U S_Kunde.Selektion
              with width 120 down.

    end. /* if */
  end. /* each bArtkunde */
end. /* for each S_Kunde */



/* ---------------------------------------------------------------------------- */

/*Table - 6*/

define variable iCount    as integer   no-undo.
define variable cTempList as character no-undo.
define variable iMaxCount as integer   no-undo.
define variable cArt      as character no-undo.
define variable cMaxList  as character no-undo.

/* loop check all Artikel */
for each S_Artikel
  where S_Artikel.Firma    = {firma/sartikel.fir '100':U}
  no-lock:

  assign
    iCount    = 0
    cTempList = ''
    .

  /* Count Kunde and sum list relation S_Artkunde */
  for each S_Artkunde
    where S_Artkunde.Firma   = {firma/sartkund.fir '100':U}
      and S_Artkunde.Artikel = S_Artikel.Artikel
    no-lock:

      assign
        iCount    = iCount + 1
        cTempList = cTempList
                  + (if cTempList = '' then
                       ''
                     else
                       ',')
                  + string(S_Artkunde.Kunde)
      .

  end. /* for each bS_Artkunde */

  /* check most count in relation */
  /* Use > so that if the same value is found later will not change the value */
  if iCount > iMaxCount then
    assign
      iMaxCount = iCount
      cArt      = S_Artikel.Artikel
      cMaxList  = cTempList
      .

end. /* for each S_Artikel */

if cArt <> '' then
do:
  display
    cArt + '; ' + cMaxList + '; ' + string(iMaxCount)
    format 'x(70)' column-label 'Result Output':U.
end. /* if cArt */
      
