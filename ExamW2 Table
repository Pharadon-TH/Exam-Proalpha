/*Table - 9*/

define variable iCount   as integer   no-undo.
define variable cArtList as character no-undo.
define variable lStart2  as logical   no-undo.

/* loop all Kunde */
for each S_Kunde
  where S_Kunde.Firma  = {firma/s_kunde.fir '100':U}
  no-lock:

  assign
    iCount   = 0
    cArtList = ''
    lStart2  = false
    .

  /* loop check Artkunde */
  for each S_ArtKunde
    where S_ArtKunde.Firma   = {firma/sartkund.fir '100':U}
      and S_ArtKunde.Kunde   = S_Kunde.Kunde
    no-lock:

    assign
      iCount   = iCount + 1

      /* give Artikel in list */
      cArtList = cArtList
               + (if cArtList = '' then
                    ''
                  else
                    ',')
               + string(S_Artkunde.Artikel)
      .

    /* check primary key show '2' in first position */
    if string(S_Artkunde.Artikel) begins '2' then
      lStart2 = true.

  end. /* for each S_ArtKunde */



  /* check conditions in Example */
  if iCount > 0 and iCount <= 5 and lStart2 = true then
  do:
    display string(S_Kunde.Kunde) + ',' + cArtList
            format 'x(60)' column-label 'Output'
            with width 100 down.
  end. /* if */
end. /* for each S_Kunde */

/* ---------------------------------------------------------------------------- */

/*Table - 10*/

/* loop all S_Artikel */
for each S_Artikel
  where S_Artikel.Firma    = {firma/sartikel.fir '100':U}
  no-lock:

  /* Try to find the Artikel connected to Artkunde */
  find first S_Artkunde
    where S_Artkunde.Firma   = {firma/sartkund.fir '100':U}
      and S_Artkunde.Artikel = S_Artikel.Artikel
    no-lock no-error.

    /* Check that can't find it */
    if not available S_Artkunde then
    do:
      display S_Artikel.Artikel     column-label 'Artikel':U
              S_Artikel.ArtikelArt  column-label 'ArtikelArt':U
              S_Artikel.Suchbegriff column-label 'Suchbegriff':U
      with width 120 down.
    end. /* if */
end. /* for each S_Artikel */

/* ---------------------------------------------------------------------------- */

/*Table - 11*/

/* loop find all S_Artkunde */
for each S_Artkunde
  where S_Artkunde.Firma   = {firma/sartkund.fir '100':U}
  no-lock:

  /* check Artikel first position '3' */
  find first S_Artikel
    where S_Artikel.Firma    = {firma/sartikel.fir '100':U}
      and S_Artikel.Artikel  = S_Artkunde.Artikel
      and S_Artikel.Artikel  begins '3'
    no-lock no-error.

  if available S_Artikel then
  do:
    /* find description in S_ArtikelSpr */
    find first S_ArtikelSpr
      where S_ArtikelSpr.Firma    = {firma/sartikel.fir '100':U}
        and S_ArtikelSpr.Artikel  = S_Artikel.Artikel
      no-lock no-error.

    /* find S_Kunde  */
    find first S_Kunde
      where S_Kunde.Firma  = {firma/s_kunde.fir '100':U}
        and S_Kunde.Kunde  = S_Artkunde.Kunde
      no-lock no-error.

    if available S_Kunde then
    do:
      find first S_Adresse
        where S_Adresse.Firma     = {firma/s_adres.fir '100':U}
          and S_Adresse.AdressNr  = S_Kunde.AdressNr
        no-lock no-error.

      display S_Artikel.Artikel           column-label 'Artikel':U
              S_ArtikelSpr.Bezeichnung[1] column-label 'description1':U format 'x(20)'
              S_ArtikelSpr.Bezeichnung[2] column-label 'description2':U format 'x(20)'
              S_Kunde.Kunde               column-label 'Kunde':U
              S_Adresse.Name1             column-label 'KundeName1':U format 'x(20)'
              S_Adresse.Telefon           column-label 'Telefon':U
              with width 150 down.

    end. /* if available S_Kunde */
  end. /* if available S_Artikel */
end. /* for each S_Artkunde */
  
