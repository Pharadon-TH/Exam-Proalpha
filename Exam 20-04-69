/*Problem - 03*/

define variable cInput as character initial 'artikel, kunde, lieferchien, rechnung' no-undo.
define variable cResult as character initial '' no-undo.
define variable cTemp as character no-undo.
define variable i as integer no-undo.

do:
   i = 1 to entry(cInput):
   cTemp = entry(i, cInput).
   
   cTemp = substring(cTemp, 1 , 3) + 'PROALPHA':U.
   cResult = cResult + cTemp.
   cResult = replace(cResult, 'e', 'T').
end.

message cResult.

