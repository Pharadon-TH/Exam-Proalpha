def var cInput        as character initial 'this is a message to be count' no-undo.
def var cCharList     as character no-undo.
def var cCountList    as character no-undo.
def var cChar         as character no-undo.
def var i             as integer   no-undo.
def var iPos          as integer   no-undo.
def var iCurrentCount as integer   no-undo.
def var cResult       as character no-undo.

/*Logic Count*/
do i = 1 to length(cInput):
  cChar = substring(cInput, i, 1).

  if cChar = ' ' then next.

  iPos = lookup(cChar, cCharList).

  if iPos = 0 then
  do:
    if cCharList = '' then
    do:
      cCharList = cChar.
      cCountList = '1'.
    end. /*if cCharList*/

    else
    do:
      cCharList = cCharList + ',' + cChar.
      cCountList = cCountList + ',' + '1'.
    end. /*else*/
  end. /*if iPos*/

  else
  do:
    iCurrentCount = integer(entry(iPos, cCountList)) + 1.
    entry(iPos, cCountList) = string(iCurrentCount).
  end. /*else*/

end. /*do*/

/*Format Display*/
do i = 1 to num-entries(cCharList):
  cResult = cResult + entry(i, cCharList) + ' = ' +
                      entry(i, cCountList) + '~n'.
end. /*do*/

/*Result*/
message 'Result: ' + '~n' + cResult.

