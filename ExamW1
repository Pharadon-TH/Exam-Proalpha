define variable cData      as character no-undo.
define variable cCode      as character no-undo.
define variable lIsValid   as logical   no-undo.
define variable iDashCount as integer   no-undo.
define variable cValid     as character no-undo.
define variable cInvalid   as character no-undo.
define variable i          as integer   no-undo.
define variable j          as integer   no-undo.
define variable cChar      as character no-undo.

assign
  cData = 'AB123;XY_456;99-ZZ;A1B2C3;abcd1234;a-b-c-d;ABC;A23456789;-ABC123;A*BC123;ZZZ-123'.

do i = 1 to num-entries(cData, ';'):
  assign
    cCode      = entry(i , cData, ';')
    lIsValid   = true
    iDashCount = 0.
    
  /* Check length 5-8 */
  if length(cCode) < 5 or length(cCode) > 8  then
    lIsValid = false.
  
  /* Check that it starts with a letter */
  if lIsValid then
  do:
    cChar = substring(cCode, 1, 1).

  if not (cChar >= 'A' and cChar <= 'Z') then
    lIsValid = false.
  end. /* if */

  /* Check special characters */
  if lIsValid then
  do j = 1 to length(cCode):
    cChar = substring(cCode, j, 1).
  
    if cChar = '-' then
      iDashCount = iDashCount + 1.

    else if not ((cChar >= 'A' and cChar <= 'Z') or (cChar >= '0' and cChar <= '9')) then
    do:
      lIsValid = false.
      leave.
    end. /* else */

    /* If marked '-' more than 1 time */
    if iDashCount > 1 then
    do:
      lIsValid = false.
      leave.
    end. /* if */
  end. /* do j */

  /* Result */
  if lIsValid then
    cValid = cValid + (if cValid = '' then '' else ', ') + cCode.

  else
    cInvalid = cInvalid + (if cInvalid = '' then '' else ', ') + cCode.
    
end. /* do i */

message 'Valid code: ' cValid skip(1)
        'Invalid code: ' cInvalid.



