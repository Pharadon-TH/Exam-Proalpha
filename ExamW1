  if dCurrentSales < dMin then
  assign
    dMin = dCurrentSales
    cMinDays = cCurrentDate + ' ' + cCurrentSales .

  else if dCurrentSales = dMin then
    cMinDays = cMinDays + '~n' + cCurrentDate + ' ' + cCurrentSales.

