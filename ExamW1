    do:
      i = i + 1.
      next.
    end.
    
    /*Look at the next one*/
    if i < length(cInput) then
      cNext = substring(cInput, i + 1, 1).

    else
      cNext = ''.
  
    if cNext >= "0" and cNext <= "9" then 
    do:
      do n = 1 to integer(cNext):
