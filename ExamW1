define variable iQty       as integer   no-undo.
define variable dPrice     as decimal   no-undo.
define variable dTotal     as decimal   no-undo.
define variable dPayment   as decimal   no-undo.
define variable dChange    as decimal   no-undo.

repeat:

  update
    cItem label 'Product Category (A,B,C,D,E,F)'
    iQty label 'Quantity purchased'.

    assign
      cItem = upper(cItem)
      cItem = upper(cItem)
      cItem = upper(cItem)
      cItem = upper(cItem)
      .

    case cItem:
    
      when 'A':U then
        dPrice = 10.
      when 'B':U then
        dPrice = 41.
      when 'C':U then
        dPrice = 32.
      when 'D':U then
        dPrice = 77.
      when 'E':U then
        dPrice = 105.
      when 'F':U then
        dPrice = 8.
      otherwise
      do:
        message 'No Item'.
        undo, retry.
      end. /* otherwise */
    end case.

    if iQty <= 0 then
    do:
        message 'Please specify the quantity'.
        undo, retry.
    end. /* if iQty <= 0 then */
    
    leave.
end. /* repeat: */

/*Total Price*/
