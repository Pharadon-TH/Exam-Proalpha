/*Table - 4*/

define buffer bArtkunde for S_Artkunde.
define buffer bKunde    for S_kunde.

/* Loop find all S_Artikel */
for each S_Artikel
  no-lock:

  /* Check S_Artikel in S_Artkunde*/
  find first bArtkunde
    where bArtkunde.Firma   = {firma/sartkund.fir '100'}
      and bArtkunde.Artikel = S_Artikel.Artikel
    no-lock no-error.

  /* Check Kunde have 1 */
  if available bArtkunde then
  do:

    /* Retrieving the first S_Kunde element from the main table */
    find first bArtkunde
      where bArtkunde.Firma   = {firma/sartkund.fir '100'}
        and bArtkunde.Kunde   = bArtkunde.Kunde
      no-lock no-error.
      
    if available bArtkunde then
    do:
      display 'Artikel: ' S_Artikel.Artikel skip
              'ArtikelArt: ' S_Artikel.ArtikelArt skip
              'LagerGewicht: ' S_Artikel.LagerGewicht skip
              'First Kunde: ' bArtkunde.Kunde.
    end. /* if */
  end. /* if */
end. /* for */

/* ---------------------------------------------------------------------------- */

/*Table - 5*/

define buffer bArtkunde for S_Artkunde.
define buffer bArtikel  for S_Artikel.

/* Loop Kunde 100000-100017 */
for each S_Kunde
  where S_Kunde.Firma  = {firma/s_kunde.fir '100'}
    and S_Kunde.Kunde  >= 100000
    and S_Kunde.Kunde  <= 100017
  no-lock:


  /* find relation S_Artkunde table */
  for each bArtkunde
    where bArtkunde.Firma   = {firma/sartkund.fir '100'}
      and bArtkunde.Kunde   = S_Kunde.Kunde
    no-lock:

    /* check condition ArtikelArt*/
    find first bArtikel
      where bArtikel.Firma    = {firma/s_kunde.fir '100'  }
        and bArtikel.Artikel  = bArtkunde.Artikel
        and lookup(string(bArtikel.ArtikelArt), '61,10,9,5,1') > 0
      no-lock no-error.
      
    if available bArtikel then
    do:
      display 'Artikel: ' bArtikel.Artikel skip
              'ArtikelArt: ' bArtikel.ArtikelArt skip
              'Kunde: ' S_Kunde.Kunde skip
              'Selektion ' S_Kunde.Selektion.

    end. /* if */
  end. /* each bArtkunde */
end. /* for each S_Kunde */


/* ---------------------------------------------------------------------------- */

/*Table - 6 (Final)*/ 

define buffer bS_Artkunde for S_Artkunde.

define variable iCount    as integer   no-undo.
define variable cTempList as character no-undo.
define variable iMaxCount as integer   no-undo.
define variable cMaxArt   as character no-undo.
define variable cMaxList  as character no-undo.

/* loop check all Artikel */
for each S_Artikel
  where S_Artikel.Firma    = {firma/sartikel.fir '100':U}
  no-lock:

  assign
    iCount    = 0
    cTempList = ''
    .

  /* Count Kunde and sum list relation S_Artkunde */
  for each bS_Artkunde
    where bS_Artkunde.Firma   = {firma/sartkund.fir '100':U}
      and bS_Artkunde.Artikel = S_Artikel.Artikel
    no-lock:

        assign
          iCount    = iCount + 1
          cTempList = cTempList
                    + (if cTempList = '' then
                         ''
                       else
                         ',')
                    + string(bS_Artkunde.Kunde)
          .

  end. /* for each bS_Artkunde */

  /* check most count in relation */
  /* Use > so that if the same value is found later will not change the value */
  if iCount > iMaxCount then
    assign
      iMaxCount = iCount
      cMaxArt   = S_Artikel.Artikel
      cMaxList  = cTempList
      .

end. /* for each S_Artikel */

if cMaxArt <> '' then
do:
  display
    cMaxArt + '; ' + cMaxList + '; ' + string(iMaxCount)
    format 'x(70)' column-label 'Result Output'.
end. /* if cMaxArt */
      
/* ---------------------------------------------------------------------------- */

/*Table - 7*/

define buffer bS_Artkunde for S_Artkunde.
define buffer bS_Kunde    for S_Kunde.

define variable iCount     as integer   no-undo.
define variable cKundeName as character no-undo.

/* loop find all S_Artikel */
for each S_Artikel
  where S_Artikel.Firma    = {firma/sartikel.fir '100':U}
  no-lock:

  assign
    iCount     = 0
    cKundeName = ''
    .

  /* count Kunde is relation in bS_Artkunde */
  for each bS_Artkunde
    where bS_Artkunde.Firma   = {firma/sartkund.fir '100':U}
      and bS_Artkunde.Artikel = S_Artikel.Artikel
    no-lock:

    /* find 1 Kunde*/
    find first bS_Kunde
      where bS_Kunde.Firma  = {firma/s_kunde.fir '100':U}
        and bS_Kunde.Kunde  = bS_Artkunde.Kunde
      no-lock no-error.

      if available bS_Kunde then
      do:

        assign
          iCount = iCount + 1
          cKundeName = string(bS_Kunde.Kunde)
          .

      end. /* if */
  end. /* for each bS_Artkunde */

  /* check only 1 Kunde */
  if iCount = 1 then
  do:
   display S_Artikel.Artikel column-label 'Artikel'
           cKundeName column-label 'The Only Kunde'.
  end. /* if */
end. /* for each S_Artikel */
